# Ignore system files
.DS_Store
.Rhistory

# Ignore parent directories
../
../../

# Ignore development files
*.py
*.R

# Ignore specific large files
*.pdf
*.docx
*.doc
*.txt
*.csv

# Keep project essentials
!assets/
!assets/data/
!assets/data/*.json
!assets/documents/*.html
!assets/images/
!css/
!js/
!.github/
!tests/
!.gitignore
!.nojekyll
!index.html
!README.md
!package.json
!package-lock.json
!playwright.config.js
!AGENTS.md